MAX_N_CLUSTERS = 15
MIN_SILHOUETTE_SCORE = 0.3

PRIORITY_THRESHOLDS = {
    "CRITICAL": 80,
    "HIGH": 60,
    "MEDIUM": 40,
    "LOW": 0,
